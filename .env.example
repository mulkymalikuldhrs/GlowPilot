# ============================================
# GlowPilot Environment Configuration
# ============================================
# Copy this file to .env.local and fill in your values.
# Never commit .env.local to version control.

# --------------------------------------------
# Firebase Configuration
# Required for authentication and data storage.
# Get these from: https://console.firebase.google.com/
# Project Settings > General > Your apps > Web app > Config
# --------------------------------------------
NEXT_PUBLIC_FIREBASE_API_KEY=your_firebase_api_key_here
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=your_project.firebaseapp.com
NEXT_PUBLIC_FIREBASE_PROJECT_ID=your_project_id
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=your_project.appspot.com
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=your_sender_id
NEXT_PUBLIC_FIREBASE_APP_ID=your_app_id
NEXT_PUBLIC_FIREBASE_MEASUREMENT_ID=G-XXXXXXXXXX

# --------------------------------------------
# Google Genkit AI Configuration
# Required for AI-powered features (diagnosis, chat, catalog).
# Get your API key from: https://aistudio.google.com/app/apikey
# You can provide multiple keys separated by commas for rotation.
# --------------------------------------------
GEMINI_API_KEY=your_gemini_api_key_here
# For key rotation (optional): GEMINI_API_KEY=key1,key2,key3

# --------------------------------------------
# Stripe Configuration (Optional)
# Required for subscription and payment features.
# Get these from: https://dashboard.stripe.com/apikeys
# --------------------------------------------
# STRIPE_SECRET_KEY=sk_test_your_stripe_secret_key
# STRIPE_WEBHOOK_SECRET=whsec_your_webhook_secret
# NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_your_publishable_key
